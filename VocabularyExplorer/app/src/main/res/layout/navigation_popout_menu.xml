<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/rounded_top_corners">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/mode_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:scaleX="1.3"
            android:scaleY="1.3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:thumbTint="@drawable/thumb_track"
            app:trackTint="@drawable/switch_track" />

        <TextView
            android:id="@+id/mode_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="21dp"
            android:text="Novice Mode"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/mode_switch"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="336dp"
                android:layout_height="48dp"
                android:background="@drawable/rounded_purple_background_rectangle" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/book"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:elevation="8dp"
            android:layout_marginStart="15dp"
            android:src="@drawable/book"
            app:layout_constraintTop_toTopOf="@id/layout1"
            app:layout_constraintBottom_toBottomOf="@id/layout1"
            app:layout_constraintStart_toStartOf="@id/layout1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="21dp"
            android:elevation="8dp"
            android:text="Word Categories"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/layout1"
            app:layout_constraintBottom_toBottomOf="@id/layout1"
            app:layout_constraintStart_toEndOf="@id/book"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="336dp"
                android:layout_height="48dp"
                android:background="@drawable/rounded_purple_background_rectangle" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/minigame"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:elevation="8dp"
            android:layout_marginStart="15dp"
            android:src="@drawable/minigame"
            app:layout_constraintTop_toTopOf="@id/layout2"
            app:layout_constraintBottom_toBottomOf="@id/layout2"
            app:layout_constraintStart_toStartOf="@id/layout2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:elevation="8dp"
            android:text="Matching Minigame"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/layout2"
            app:layout_constraintBottom_toBottomOf="@id/layout2"
            app:layout_constraintStart_toEndOf="@id/minigame"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="336dp"
                android:layout_height="48dp"
                android:background="@drawable/rounded_purple_background_rectangle" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/semantic_gaps"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:elevation="8dp"
            android:layout_marginStart="15dp"
            android:src="@drawable/semantic_gaps"
            app:layout_constraintTop_toTopOf="@id/layout3"
            app:layout_constraintBottom_toBottomOf="@id/layout3"
            app:layout_constraintStart_toStartOf="@id/layout3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:elevation="8dp"
            android:text="Semantic Gaps"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/layout3"
            app:layout_constraintBottom_toBottomOf="@id/layout3"
            app:layout_constraintStart_toEndOf="@id/semantic_gaps"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="336dp"
                android:layout_height="48dp"
                android:background="@drawable/rounded_purple_background_rectangle" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:elevation="8dp"
            android:layout_marginStart="15dp"
            android:src="@drawable/close"
            app:layout_constraintTop_toTopOf="@id/layout4"
            app:layout_constraintBottom_toBottomOf="@id/layout4"
            app:layout_constraintStart_toStartOf="@id/layout4"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:elevation="8dp"
            android:text="Close"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/layout4"
            app:layout_constraintBottom_toBottomOf="@id/layout4"
            app:layout_constraintStart_toEndOf="@id/close"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>